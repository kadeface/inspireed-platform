# 开发环境配置
# API配置 - 留空将自动根据访问地址动态适配
# VITE_API_BASE_URL=

# 应用配置
VITE_APP_TITLE=InspireEd (开发)
VITE_APP_VERSION=1.0.0-dev

# 调试日志配置（开发环境启用）
VITE_ENABLE_DEBUG_LOGS=true

# 日志级别: DEBUG, INFO, WARN, ERROR
VITE_LOG_LEVEL=DEBUG

# 启用的日志模块（逗号分隔）：API,LESSON,ACTIVITY,WEBSOCKET,SESSION,ASSISTANT,CLASSROOM
# 留空或 * 表示启用所有模块
VITE_DEBUG_MODULES=
