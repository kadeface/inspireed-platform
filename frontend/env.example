# API配置
# 本地开发使用 localhost
VITE_API_BASE_URL=http://localhost:8000/api/v1

# 局域网访问时，请将下面的 IP 地址替换为运行后端服务器的实际 IP 地址
# 例如：VITE_API_BASE_URL=http://192.168.1.100:8000/api/v1
# 如何获取 IP 地址：
# - macOS/Linux: 运行 ifconfig 或 ip addr
# - Windows: 运行 ipconfig
# 查找类似 192.168.x.x 或 10.0.x.x 的地址

# 应用配置
VITE_APP_TITLE=InspireEd
VITE_APP_VERSION=1.0.0

# 开发服务器是否使用 HTTPS（启用时会加载 @vitejs/plugin-basic-ssl）
# 默认不设置或设为 false：使用 http://localhost:5173，兼容 Node 22.21+ 本地开发
# 设为 true：使用 https://localhost:5173（在部分 Node 22.21+ 版本可能与 basic-ssl 不兼容导致 dev 崩溃，可改用 Node 22.20.x 或 LTS 20）
# VITE_DEV_HTTPS=false

