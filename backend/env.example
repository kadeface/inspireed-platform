# 应用配置
PROJECT_NAME=InspireEd
VERSION=1.0.0
API_V1_STR=/api/v1
# ENVIRONMENT=development | production
ENVIRONMENT=development
# 是否启用 API 文档（/docs, /redoc），生产环境建议关闭
DOCS_ENABLED=true

# 安全配置
# 生产环境必须设置一个随机字符串，例如: openssl rand -hex 64
SECRET_KEY=
ALGORITHM=HS256
# Token 过期时间（分钟），默认 1440 = 1 天
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - 允许局域网访问
# 格式：逗号分隔的URL列表，或JSON数组格式
# 示例: BACKEND_CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
# BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 是否允许局域网IP通配，生产环境应设为 false
ALLOW_LAN_ACCESS=true

# 数据库配置
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inspireed
POSTGRES_PORT=5432

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=inspireed
MINIO_SECURE=false

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_LESSON_LOGS_TOPIC=lesson_logs
KAFKA_QA_LOGS_TOPIC=qa_logs

# JupyterHub配置
JUPYTERHUB_URL=http://localhost:8000
JUPYTERHUB_API_TOKEN=

# OpenAI配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
DEFAULT_AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=20000
AI_TEMPERATURE=0.7

# 超级管理员
FIRST_SUPERUSER=admin@inspireed.com
FIRST_SUPERUSER_PASSWORD=admin123

# 文件上传大小限制（字节），默认 100MB
MAX_UPLOAD_SIZE=104857600

# 资源URL配置
RESOURCE_BASE_PATH=/uploads/resources
# RESOURCE_BASE_URL=http://localhost:8000

